# Codify — required environment variables
# Set these in Vercel dashboard for production, .env.local for local dev
# NEVER commit actual values to git

# Stripe
STRIPE_SECRET_KEY=sk_live_...
STRIPE_WEBHOOK_SECRET=whsec_...

# GoHighLevel
GHL_API_KEY=

# Google AI (scan pipeline)
GOOGLE_AI_API_KEY=

# Scan pipeline webhook
SCAN_WEBHOOK_URL=
WEBHOOK_SECRET=

# OpenRouter (trial key distribution)
TRIAL_OPENROUTER_KEY=

# Supabase (server-side — for webhook inserts)
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=eyJ...
SUPABASE_SERVICE_ROLE_KEY=eyJ...

# GitHub (vault provisioning — needs repo create + contents write)
GITHUB_TOKEN=ghp_...
